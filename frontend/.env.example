# Backend API base URL (leave empty to use dev proxy)
# Production: set to your backend's public URL, e.g. https://ai-proofreader-v2.zeabur.app
VUE_APP_API_BASE=

# SSE direct connection URL (leave empty to fall back to VUE_APP_API_BASE)
VUE_APP_SSE_BASE=

# Application API Key (optional, must match backend)
VUE_APP_API_KEY=
